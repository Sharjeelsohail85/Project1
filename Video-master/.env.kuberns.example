# Backend service environment for Kuberns.
APP_NAME="Project1 Video API"
APP_ENV=production
APP_KEY=base64:ivhNnMxrTMniMMH5bGuCwWKJQKrisJbanAUsAYMEme0=
APP_DEBUG=false
APP_LOG_LEVEL=info
APP_URL=https://project1-backend-your-id.kuberns.com
FRONTEND_URL=https://project1-frontend-your-id.kuberns.com
SANCTUM_STATEFUL_DOMAINS=project1-frontend-your-id.kuberns.com

# Kuberns injects PORT automatically for web services. The Dockerfile defaults to 8080.
PORT=8080

# Use Kuberns managed MySQL if you add a database to the backend service.
DB_CONNECTION=mysql
DB_HOST=replace_with_kuberns_mysql_host
DB_PORT=3306
DB_DATABASE=replace_with_kuberns_mysql_database
DB_USERNAME=replace_with_kuberns_mysql_user
DB_PASSWORD=replace_with_kuberns_mysql_password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_DRIVER=sync
QUEUE_CONNECTION=sync
LOG_CHANNEL=stderr

# Set to true only after DB_* variables point to a working database.
RUN_MIGRATIONS=false

MAIL_DRIVER=log
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Project1 Video API"

MIGRATION_PROVIDER_SANDBOX_MODE=true
MIGRATION_UPLOAD_PROVIDER=hetzner

