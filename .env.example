# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_ONEDRIVE_CLIENT_ID: Azure Application (client) ID for seamless Microsoft OneDrive integration
VITE_ONEDRIVE_CLIENT_ID="fac31fe1-c18e-4894-aa70-6589ae18d996"

# VITE_ONEDRIVE_TENANT_ID: Azure Directory (tenant) ID for OneDrive integration (optional, defaults to 'common')
VITE_ONEDRIVE_TENANT_ID="9e7c38c3-66a5-4f8d-bdca-a8d195af3fff"

# VITE_ONEDRIVE_PRIMARY_DOMAIN: Primary domain for Microsoft Entra integration
VITE_ONEDRIVE_PRIMARY_DOMAIN="sharjeelsohail85gmail.onmicrosoft.com"

# VITE_ONEDRIVE_NAME: Microsoft Entra Directory Name
VITE_ONEDRIVE_NAME="Default Directory"

# VITE_ONEDRIVE_LICENSE: Microsoft Entra ID License type
VITE_ONEDRIVE_LICENSE="Microsoft Entra ID Free"

